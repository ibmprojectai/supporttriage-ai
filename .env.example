# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit credentials.

# Ollama base URL — defaults to http://localhost:11434 when unset
# Only change this if you run Ollama on a different host or port.
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model name — defaults to granite3-dense:8b when unset
# Pull it with: ollama pull granite3-dense:8b
OLLAMA_MODEL=granite3-dense:8b

# OpenRouter API key — if set, uses OpenRouter cloud inference instead of Ollama
# Get your key at https://openrouter.ai/keys
# Leave unset to use local Ollama instead.
OPENROUTER_API_KEY=your_openrouter_key_here

# ChromaDB persistence directory — defaults to .chromadb when unset
CHROMA_PERSIST_DIR=.chromadb

# IMAP server for email intake — defaults to imap.gmail.com when unset
IMAP_SERVER=imap.gmail.com
