# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit credentials.

# ── Ollama (local LLM) ─────────────────────────────────────────────────────
# Ollama base URL — defaults to http://localhost:11434 when unset
# Only change this if you run Ollama on a different host or port.
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model name — defaults to granite3-dense:8b when unset
# Pull it with: ollama pull granite3-dense:8b
OLLAMA_MODEL=granite3-dense:8b

# ── OpenRouter (cloud LLM) ─────────────────────────────────────────────────
# OpenRouter API key — if set, uses OpenRouter cloud inference instead of Ollama
# Get your key at https://openrouter.ai/keys
# Leave unset to use local Ollama instead.
OPENROUTER_API_KEY=your_openrouter_key_here

# ── ChromaDB ───────────────────────────────────────────────────────────────
# ChromaDB persistence directory — defaults to .chromadb when unset
CHROMA_PERSIST_DIR=.chromadb

# ── Email (Gmail) ──────────────────────────────────────────────────────────
# Destination inbox for tickets submitted via the web form.
# Set to your support team inbox; falls back to GMAIL_USER if unset.
SUPPORT_EMAIL=support@yourcompany.com

# Gmail address used for SMTP sending (web form) and IMAP reading (inbox).
GMAIL_USER=your-gmail@gmail.com

# Gmail App Password (NOT your account password).
# Generate one at: myaccount.google.com/apppasswords
# Requires 2-Step Verification enabled on the account.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# SMTP server for sending web form confirmation emails.
SMTP_SERVER=smtp.gmail.com

# IMAP server for reading incoming support tickets.
IMAP_SERVER=imap.gmail.com
